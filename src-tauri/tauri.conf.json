{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tributary",
  "version": "0.1.2",
  "identifier": "dev.tributary.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Tributary",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 560,
        "transparent": true,
        "shadow": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://gravatar.com https://secure.gravatar.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data: https://fonts.gstatic.com;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5MEYyMEEwMDA2QkFFRDUKUldUVnJtc0FvQ0FQbWNMSDNJa3hRa2xKc1o5Rnd0OXkrV0s4UUpnQTZ1V0JockM2SzBVbUtwbkwK",
      "endpoints": [
        "https://github.com/thistine/tributary/releases/latest/download/latest.json"
      ]
    }
  }
}
